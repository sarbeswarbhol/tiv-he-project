# Backend environment variables
# Copy this file to .env and fill in your real values.

# JWT signing secret used for access tokens
JWT_SECRET_KEY=your_jwt_secret_key_here

# Token signing secret used for secure token generation and verification
TOKEN_SIGNING_SECRET=your_token_signing_secret_here

# Fernet key used for symmetric encryption of PII
FERNET_KEY=your_fernet_key_here

# Database connection
DATABASE_URL=postgresql+psycopg2://user:password@host:port/dbname?sslmode=require

# Alternatively use component values if DATABASE_URL is not set
PGHOST=your_db_host
PGUSER=your_db_user
PGPASSWORD=your_db_password
PGDATABASE=your_db_name

# Frontend origins allowed by CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Token expiration in hours
ACCESS_TOKEN_EXPIRE_HOURS=24

# ── Blockchain (Sepolia testnet) ─────────────────────────
# Get a free RPC URL from: https://app.infura.io  or  https://dashboard.alchemy.com
BLOCKCHAIN_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Address of your deployed CredentialRegistry contract on Sepolia
BLOCKCHAIN_CONTRACT_ADDRESS=0xYourDeployedContractAddress

# Private key of the wallet that owns the contract (never commit this!)
BLOCKCHAIN_PRIVATE_KEY=0xYourPrivateKey

# Public address of that same wallet
BLOCKCHAIN_WALLET_ADDRESS=0xYourWalletAddress

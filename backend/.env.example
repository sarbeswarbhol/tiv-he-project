# Backend environment variables
# Copy this file to .env and fill in your real values.

# JWT signing secret used for access tokens
JWT_SECRET_KEY=your_jwt_secret_key_here

# Token signing secret used for secure token generation and verification
TOKEN_SIGNING_SECRET=your_token_signing_secret_here

# Fernet key used for symmetric encryption of PII
FERNET_KEY=your_fernet_key_here

# Database connection
DATABASE_URL=postgresql+psycopg2://user:password@host:port/dbname?sslmode=require

# Alternatively use component values if DATABASE_URL is not set
PGHOST=your_db_host
PGUSER=your_db_user
PGPASSWORD=your_db_password
PGDATABASE=your_db_name

# Frontend origins allowed by CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Token expiration in hours
ACCESS_TOKEN_EXPIRE_HOURS=24
